<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <!--
                %X{transactionId} reads from MDC — populated by TransactionLoggingFilter.
                Displays empty string when no transactionId is present (e.g. startup logs).
                ISO8601 produces "2026-02-21 13:45:00,123" — sortable and unambiguous.
            -->
            <pattern>%d{ISO8601} [%thread] %-5level %logger{36} [txId=%X{transactionId}] - %msg%n</pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="STDOUT" />
    </root>
    
    <logger name="com.gymcrm" level="DEBUG"/>
</configuration>
